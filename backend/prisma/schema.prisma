// ============================================================
// Digital Loyalty Voucher SaaS — Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  BUSINESS_ADMIN
  STAFF
  CUSTOMER
}

enum BusinessStatus {
  PENDING
  ACTIVE
  SUSPENDED
  PAST_DUE
  DELETED
}


enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum CheckInStatus {
  VALID
  SUSPICIOUS
  REJECTED
}

enum LoyaltyType {
  VISIT_BASED
  POINTS_BASED
  SPEND_BASED
}

enum LoyaltyResetMode {
  FULL_RESET      // counter/points reset to 0 after redemption
  CARRY_REMAINDER // surplus visits/points carry over
}

enum CustomerRewardStatus {
  LOCKED
  UNLOCKED
  REDEEMED
  EXPIRED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum NotificationType {
  REWARD_UNLOCKED
  SUBSCRIPTION_EXPIRING
  BUSINESS_SUSPENDED
  COUPON_AVAILABLE
  GENERAL
}

enum LoyaltyRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────

/// Platform user — covers all roles (SUPER_ADMIN, BUSINESS_ADMIN, STAFF, CUSTOMER).
/// Customers use OTP-only auth (passwordHash is null). Staff/admins use password auth.
model User {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  passwordHash String?                      // null for OTP-only customers
  role         Role      @default(CUSTOMER)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?                    // GDPR soft-delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  ownedBusinesses      Business[]           @relation("BusinessOwner")
  staffProfile         Staff?
  customerPoints       CustomerPoints[]
  checkIns             CheckIn[]
  customerRewards      CustomerReward[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  otpVerifications     OtpVerification[]
  refreshTokens        RefreshToken[]
  loyaltyRequests      LoyaltyRequest[]
  loyaltyTransactions  LoyaltyTransaction[]
  reviewGenerations    ReviewGeneration[]
  pushSubscriptions    PushSubscription[]
  userWallets          UserWallet[]
  walletTransactions   WalletTransaction[]
  loyaltyWallets       CustomerLoyaltyWallet[]
  loyaltyPointsLedgers LoyaltyPointsLedger[]
  claimedCoupons       ClaimedCoupon[]

  @@index([phone])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

/// A business tenant. Soft-deleted via deletedAt + status = DELETED.
/// Cascading suspension blocks all staff logins and QR check-ins.
model Business {
  id        String         @id @default(cuid())
  name      String
  logoUrl     String?
  coverUrl    String?
  description String?
  phone       String?
  address   String?
  timezone  String         @default("Asia/Kolkata")
  category  String?
  bookingUrl String?
  status    BusinessStatus @default(ACTIVE)
  deletedAt DateTime?

  // Social media links
  instagramUrl    String?
  facebookUrl     String?
  whatsappUrl     String?
  googleReviewUrl String?

  ownerId String
  owner   User   @relation("BusinessOwner", fields: [ownerId], references: [id])

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  subscription         Subscription?
  branches             Branch[]
  staff                Staff[]
  loyaltyPrograms      LoyaltyProgram[]
  rewards              Reward[]
  coupons              Coupon[]
  customerPoints       CustomerPoints[]
  checkIns             CheckIn[]
  notifications        Notification[]
  loyaltyLevels        LoyaltyLevel[]
  loyaltyRequests      LoyaltyRequest[]
  loyaltyTransactions  LoyaltyTransaction[]
  reviewSettings       BusinessReviewSettings?
  reviewGenerations    ReviewGeneration[]
  loyaltyProgramSettings LoyaltyProgramSettings?
  userWallets          UserWallet[]
  walletTransactions   WalletTransaction[]
  loyaltyWallets         CustomerLoyaltyWallet[]
  loyaltyPointsLedgers LoyaltyPointsLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
  @@map("businesses")
}

/// Dynamic settings configurable by Super Admin
model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}

/// A physical location of a business. Has its own GPS coordinates and signed QR token.
model Branch {
  id           String  @id @default(cuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int     @default(100) // GPS check-in acceptance radius
  qrToken      String  @unique       // HMAC-SHA256 signed token (rotatable)
  isActive     Boolean @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  staff    Staff[]
  checkIns CheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([qrToken])
  @@map("branches")
}

/// Staff member profile — linked 1:1 to a User with role=STAFF.
model Staff {
  id          String @id @default(cuid())
  /// JSON permission flags e.g. { "canManualCheckin": true }
  permissions Json   @default("{}")

  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  redeemedRewards CustomerReward[] @relation("RedeemedByStaff")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([branchId])
  @@map("staff")
}

/// Subscription plan definition. Managed by Super Admin.
model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  priceMonthly Decimal  @db.Decimal(10, 2) // INR
  maxBranches  Int
  maxCustomers Int
  /// Feature flags: { "analyticsAccess": bool, "customBranding": bool, "csvExport": bool, "apiAccess": bool }
  features     Json
  isActive     Boolean  @default(true)

  businesses    Business[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

/// One active subscription per business. Razorpay manages recurring billing.
model Subscription {
  id                     String             @id @default(cuid())
  status                 SubscriptionStatus @default(TRIAL)
  razorpaySubscriptionId String?            @unique
  currentPeriodEnd       DateTime?
  /// Auto-suspend date — set 7 days after payment failure
  gracePeriodEnd         DateTime?
  cancelledAt            DateTime?

  businessId String       @unique
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId     String
  plan       Plan         @relation(fields: [planId], references: [id])
  payments   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

/// Individual payment records linked to subscriptions.
model Payment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(10, 2) // INR
  razorpayPaymentId String?       @unique
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  /// Full Razorpay webhook payload snapshot for audit
  metadata          Json?

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([status])
  @@map("payments")
}

/// GPS-verified customer check-in at a branch.
/// Haversine distance calculated server-side and stored for audit.
model CheckIn {
  id             String        @id @default(cuid())
  latitude       Float?
  longitude      Float?
  distanceMeters Float?         // Haversine distance from branch center
  status         CheckInStatus @default(VALID)
  ipAddress      String?
  /// Client-generated UUID stored in localStorage — soft device fingerprint
  deviceId       String?

  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  // Troubleshooting GPS fields
  accuracy   Float?
  distance   Float?
  checked_at DateTime? @default(now())

  @@index([customerId, branchId])
  @@index([customerId, createdAt]) // for cooldown check query
  @@index([businessId, createdAt])
  @@index([status])
  @@map("check_ins")
}

/// Loyalty program definition per business. One active program per type per business.
model LoyaltyProgram {
  id                 String           @id @default(cuid())
  type               LoyaltyType
  /// VISIT_BASED: number of visits to earn reward. POINTS_BASED: points required for reward.
  threshold          Int
  /// Points awarded per visit (POINTS_BASED only)
  pointsPerVisit     Int              @default(10)
  pointsPerSpendUnit Float            @default(1.0)
  resetMode          LoyaltyResetMode @default(FULL_RESET)
  isActive           Boolean          @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rewardId   String
  reward     Reward   @relation(fields: [rewardId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@map("loyalty_programs")
}

/// A reward that can be earned and redeemed by customers.
model Reward {
  id             String    @id @default(cuid())
  title          String
  description    String?
  /// Used for POINTS_BASED programs — points cost of this reward
  pointsRequired Int       @default(0)
  expiryDate     DateTime?
  imageUrl       String?
  isActive       Boolean   @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  loyaltyPrograms LoyaltyProgram[]
  customerRewards CustomerReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([isActive])
  @@map("rewards")
}

/// Tracks a specific reward instance for a customer.
/// Each unlocked reward gets a unique redemption code shown to the customer.
model CustomerReward {
  id             String               @id @default(cuid())
  status         CustomerRewardStatus @default(LOCKED)
  /// Unique code shown to customer for staff redemption
  redemptionCode String               @unique @default(cuid())
  redeemedAt     DateTime?
  expiresAt      DateTime?

  customerId        String
  customer          User    @relation(fields: [customerId], references: [id])
  rewardId          String
  reward            Reward  @relation(fields: [rewardId], references: [id])
  redeemedByStaffId String?
  redeemedByStaff   Staff?  @relation("RedeemedByStaff", fields: [redeemedByStaffId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([redemptionCode])
  @@index([status])
  @@map("customer_rewards")
}

/// Time-bound discount coupon — separate from loyalty rewards.
model Coupon {
  id               String          @id @default(cuid())
  code             String          @unique
  title            String
  description      String?
  discountType     DiscountType
  discountValue    Decimal         @db.Decimal(10, 2)
  validFrom        DateTime
  validTo          DateTime
  /// null = unlimited global usage
  usageLimit       Int?
  totalUsed        Int             @default(0)
  isActive         Boolean         @default(true)
  eventDate        DateTime?       @map("event_date")
  offerTitle       String?         @map("offer_title")
  offerDescription String?         @map("offer_description")

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  usages CouponUsage[]
  claims ClaimedCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([code])
  @@index([validTo])
  @@map("coupons")
}

/// Per-customer coupon usage record — enforces one-use-per-customer limit.
model CouponUsage {
  id       String   @id @default(cuid())
  usedAt   DateTime @default(now())

  couponId   String
  coupon     Coupon @relation(fields: [couponId], references: [id])
  customerId String

  @@unique([couponId, customerId])
  @@index([couponId])
  @@map("coupon_usages")
}

model ClaimedCoupon {
  id             String    @id @default(cuid())
  couponId       String    @map("coupon_id")
  coupon         Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId     String    @map("customer_id")
  customer       User      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  claimedAt      DateTime  @default(now()) @map("claimed_at")
  redeemedAt     DateTime? @map("redeemed_at")
  status         String    @default("CLAIMED") // CLAIMED, REDEEMED, EXPIRED
  redemptionCode String    @unique @default(cuid()) @map("redemption_code")

  @@unique([couponId, customerId])
  @@map("claimed_coupons")
}

/// Denormalized points/visits counter per customer per business.
/// Updated transactionally in the loyalty engine. Source of truth for dashboard reads.
model CustomerPoints {
  id          String @id @default(cuid())
  totalPoints Int    @default(0)  // POINTS_BASED: deducted on reward unlock
  totalVisits Int    @default(0)  // lifetime valid check-ins at this business
  visitStreak Int    @default(0)  // current visit count toward next VISIT_BASED reward

  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([customerId, businessId])
  @@index([customerId])
  @@index([businessId])
  @@map("customer_points")
}

/// In-app notification for any user. Supports metadata for deep-linking.
model Notification {
  id       String           @id @default(cuid())
  title    String
  body     String
  type     NotificationType
  isRead   Boolean          @default(false)
  /// Extra context e.g. { "rewardId": "...", "businessId": "..." }
  metadata Json?

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Immutable audit trail for all significant system events.
model AuditLog {
  id         String  @id @default(cuid())
  /// e.g. "CHECK_IN_SUSPICIOUS", "REWARD_REDEEMED", "PLAN_CHANGED", "BUSINESS_SUSPENDED"
  action     String
  entityType String  // e.g. "CheckIn", "CustomerReward", "Business"
  entityId   String
  /// Full context snapshot — sufficient to reconstruct what happened
  metadata   Json?
  ipAddress  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

/// OTP verification record stored in DB (Redis swap-in ready for Phase 2).
model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  /// bcrypt hash of the OTP — never store plain OTP
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_verifications")
}

/// Hashed refresh tokens stored server-side for revocation support.
model RefreshToken {
  id        String    @id @default(cuid())
  /// SHA-256 hash of the actual token — never store raw token
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// MANUAL LOYALTY LEVEL APPROVAL SYSTEM
// ─────────────────────────────────────────────────────────────

/// Custom loyalty tier defined by a business owner (e.g. Bronze=1pt, Gold=5pt).
model LoyaltyLevel {
  id          String  @id @default(cuid())
  name        String                          // e.g. "Gold"
  description String?                         // e.g. "Frequent buyer"
  points      Int                             // e.g. 5
  sortOrder   Int     @default(0)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  loyaltyRequests      LoyaltyRequest[]
  loyaltyTransactions  LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@map("loyalty_levels")
}

/// Pending loyalty approval request — created by customer after check-in.
model LoyaltyRequest {
  id     String               @id @default(cuid())
  status LoyaltyRequestStatus @default(PENDING)

  customerId   String
  customer     User          @relation(fields: [customerId], references: [id])
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  checkInId    String?                        // Reference to triggering CheckIn
  levelId      String?                        // Set when approved
  level        LoyaltyLevel? @relation(fields: [levelId], references: [id])
  spendAmount  Decimal?      @db.Decimal(10, 2)
  approvedById String?                        // User ID of Business Admin who approved
  approvedAt   DateTime?

  loyaltyTransaction LoyaltyTransaction?

  createdAt DateTime @default(now())

  @@index([businessId, status])
  @@index([customerId])
  @@map("loyalty_requests")
}

/// Immutable record of points awarded to a customer via manual approval.
model LoyaltyTransaction {
  id          String   @id @default(cuid())
  points      Int
  extraPoints Int      @default(0) @map("extra_points")

  customerId  String
  customer    User            @relation(fields: [customerId], references: [id])
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  levelId     String?
  level       LoyaltyLevel?   @relation(fields: [levelId], references: [id])
  requestId   String?         @unique
  request     LoyaltyRequest? @relation(fields: [requestId], references: [id])
  spendAmount Decimal?        @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([businessId])
  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────────────────────
// AI REVIEW GENERATOR
// ─────────────────────────────────────────────────────────────

/// Review generator settings per business (business type + social/review URLs).
model BusinessReviewSettings {
  id              String   @id @default(cuid())
  businessType    String?  // e.g. "Cafe", "Restaurant", "Salon"
  googleReviewUrl String?
  instagramUrl    String?
  facebookUrl     String?
  googleBusinessName String?
  googlePlaceId      String?

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_review_settings")
}

/// Analytics record for each AI review generation session.
model ReviewGeneration {
  id               String   @id @default(cuid())
  rating           Int
  generatedReviews Json     // String[] — the 5 AI suggestions
  selectedReview   String?  // Which suggestion the customer picked
  reviewLinkClicked Boolean @default(false)

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([rating])
  @@map("review_generations")
}

/// Push subscriptions for Web Push notifications (VAPID).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  keys      Json     // Contains "p256dh" and "auth"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// HYBRID POINTS-TO-STAMPS LOYALTY PROGRAM
// ─────────────────────────────────────────────────────────────

model LoyaltyProgramSettings {
  id                            String   @id @default(cuid())
  businessId                    String   @unique @map("business_id")
  business                      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  programName                   String   @default("Coffee Rewards") @map("program_name")
  pointsPerRupee                Float    @default(0.1) @map("points_per_rupee")
  pointsPerStamp                Int      @default(50) @map("points_per_stamp")
  requiredStamps                Int      @default(7) @map("required_stamps")
  rewardName                    String   @default("Free Coffee") @map("reward_name")
  validityDays                  Int      @default(30) @map("validity_days")
  maxDailyStamps                Int      @default(1) @map("max_daily_stamps")
  bonusThresholdAmount          Float    @default(500) @map("bonus_threshold_amount")
  pointsPerRupeeAboveThreshold  Float    @default(0.1) @map("points_per_rupee_above_threshold")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  @@map("loyalty_program_settings")
}

model UserWallet {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId     String    @map("business_id")
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  currentPoints  Int       @default(0) @map("current_points")
  currentStamps  Int       @default(0) @map("current_stamps")
  pointsBalance  Int       @default(0) @map("points_balance")
  startedAt      DateTime? @map("started_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([userId, businessId])
  @@map("user_wallet")
}

model WalletTransaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String   @map("business_id")
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchaseValue Decimal  @db.Decimal(10, 2) @map("purchase_value")
  pointsEarned  Int      @default(0) @map("points_earned")
  stampEarned   Int      @default(0) @map("stamp_earned")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("wallet_transactions")
}

model LoyaltyPointsLedger {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId     String   @map("business_id")
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  points         Int
  purchaseAmount Float    @map("purchase_amount")
  source         String   @default("BONUS")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("loyalty_points_ledger")
}

enum LoyaltyWalletStatus {
  ACTIVE
  REWARD_AVAILABLE
  REDEEMED
  EXPIRED
}

model CustomerLoyaltyWallet {
  id               String              @id @default(cuid())
  userId           String              @map("user_id")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId       String              @map("business_id")
  business         Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  currentStamps    Int                 @default(0) @map("current_stamps")
  status           LoyaltyWalletStatus @default(ACTIVE)
  startedAt        DateTime            @default(now()) @map("started_at")
  expiresAt        DateTime            @map("expires_at")
  rewardUnlockedAt DateTime?           @map("reward_unlocked_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@map("customer_loyalty_wallet")
}
