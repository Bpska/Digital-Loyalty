# ============================================================
# Digital Loyalty Voucher SaaS — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://dlv_user:changeme@localhost:5432/dlv_db?schema=public"

# ─── Connection Pooling (CRITICAL for production) ────────────
# If using PgBouncer, set this to the bouncer URL (port 6432).
# Prisma will auto-add pgbouncer=true to disable prepared statements.
# Leave empty if connecting directly to PostgreSQL.
# DATABASE_POOL_URL="postgresql://dlv_user:changeme@localhost:6432/dlv_db?schema=public"

# Max connections PER app instance (default: 5).
# Formula: PRISMA_CONNECTION_LIMIT = floor(pg_max_connections / num_instances) - safety_margin
# Example: Postgres max_connections=100, 3 instances → 100/3 - 5 ≈ 28, but 5-10 is safer.
PRISMA_CONNECTION_LIMIT=5

# Seconds to wait for a free connection before throwing P2024 error (default: 10)
PRISMA_POOL_TIMEOUT=10

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_32chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=14d

# ─── OTP Provider ───────────────────────────────────────────
# Options: msg91 | twilio | stub (stub = logs OTP to console, for dev only)
OTP_PROVIDER=stub
OTP_API_KEY=
# MSG91 specific
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=DLVAPP
# Twilio specific
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ─── Loyalty Defaults ────────────────────────────────────────
DEFAULT_CHECKIN_RADIUS_METERS=50
DEFAULT_CHECKIN_COOLDOWN_HOURS=4
DEFAULT_POINTS_PER_VISIT=10

# ─── Storage ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=5           # requests per window
RATE_LIMIT_AUTH_WINDOW_MIN=15   # window in minutes
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_OTP_WINDOW_MIN=10
RATE_LIMIT_CHECKIN_MAX=10
RATE_LIMIT_CHECKIN_WINDOW_MIN=1

# ─── QR Token ────────────────────────────────────────────────
QR_HMAC_SECRET=change_this_to_qr_signing_secret_32chars

# ─── Redis (Phase 2 — leave empty for Phase 1) ───────────────
# REDIS_URL=redis://localhost:6379

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
